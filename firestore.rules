
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a robust, role-based security model.
     * UPDATED: Added permissions for nested chat messages.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDataOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isDataOwner(ownerId);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /hospitalProfiles/{hospitalId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(hospitalId) && request.resource.data.userId == hospitalId;
      allow update: if isExistingOwner(hospitalId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    match /engineerProfiles/{engineerId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(engineerId) && request.resource.data.userId == engineerId;
      allow update: if isExistingOwner(engineerId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    match /devices/{deviceId} {
      allow get, list: if isSignedIn() && (isDataOwner(resource.data.hospitalId) || isAdmin());
      allow create: if isSignedIn() && isDataOwner(request.resource.data.hospitalId);
      allow update: if isExistingOwner(resource.data.hospitalId) && request.resource.data.hospitalId == resource.data.hospitalId;
      allow delete: if isExistingOwner(resource.data.hospitalId) || isAdmin();
    }

    match /maintenanceRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isDataOwner(request.resource.data.hospitalId);
      allow update: if (isExistingOwner(resource.data.hospitalId) || isDataOwner(resource.data.assignedEngineerId) || isAdmin());
      allow delete: if isExistingOwner(resource.data.hospitalId) || isAdmin();

      match /bids/{bidId} {
        allow create: if isSignedIn() && isDataOwner(request.resource.data.engineerId);
        allow get, list: if isSignedIn() && (isDataOwner(resource.data.engineerId) || isDataOwner(resource.data.hospitalId) || isAdmin());
        allow update: if isExistingOwner(resource.data.engineerId) || isDataOwner(resource.data.hospitalId) || isAdmin();
        allow delete: if isExistingOwner(resource.data.engineerId) || isAdmin();
      }

      // قواعد حماية نظام الدردشة والتفاوض
      match /chats/{engineerId} {
        allow read, write: if isSignedIn() && (isDataOwner(engineerId) || isDataOwner(get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.hospitalId) || isAdmin());
        
        match /messages/{messageId} {
          allow read, write: if isSignedIn() && (isDataOwner(engineerId) || isDataOwner(get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.hospitalId) || isAdmin());
        }
      }
    }

    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId);
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) && request.resource.data.userId == userId;
      allow delete: if isAdmin(); 
    }

    match /reviews/{reviewId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isDataOwner(request.resource.data.hospitalId);
      allow update: if isExistingOwner(request.resource.data.hospitalId) && request.resource.data.hospitalId == resource.data.hospitalId;
      allow delete: if isExistingOwner(request.resource.data.hospitalId) || isAdmin();
    }
  }
}
